# Shared .env for Taobao/Tmall and JD
# Copy this file to .env, then fill in the values you actually need.

# Required: Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_FALLBACK=

# Optional: Gemini networking/model settings
GEMINI_PROXY_URL=
GEMINI_TIMEOUT_SEC=45
GEMINI_FLASH_MODEL=gemini-flash-latest
GEMINI_PRO_MODEL=gemini-3.1-pro-preview
GEMINI_PRO_RETRIES=2
GEMINI_IMAGE_MAX_CANDIDATES=24
GEMINI_IMAGE_BATCH_MAX_IMAGES=8
GEMINI_IMAGE_BATCH_MAX_BYTES=18874368

# Optional: crawl/LLM controls
SHOP_FILTER=on
CRAWL_WORKERS=1
LLM_WORKERS=64
LLM_WORKERS_MIN=32

# Optional: browser/CDP settings shared by both platforms
# Leave PLAYWRIGHT_CDP_URL empty to use the built-in raw CDP launcher.
PLAYWRIGHT_CDP_URL=
PLAYWRIGHT_HEADLESS=0
CUSTOM_BROWSER_PATH=
MANUAL_WAIT_SECONDS=0

# Taobao/Tmall session settings
# Leave USER_DATA_DIR empty to use the default OS-specific profile path.
TAOBAO_BROWSER_MODE=cdp
TAOBAO_USER_DATA_DIR=
TAOBAO_STORAGE_STATE_FILE=data/taobao_storage_state.json
TAOBAO_MANUAL_LOGIN_TIMEOUT_SEC=300

# JD session settings
# Use separate paths from Taobao so cookies and risk controls do not mix.
JD_BROWSER_MODE=cdp
JD_USER_DATA_DIR=
JD_STORAGE_STATE_FILE=data/jd_storage_state.json
JD_MANUAL_LOGIN_TIMEOUT_SEC=300
